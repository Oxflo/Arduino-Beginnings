int led_pin = 13; //makes pin 13 a variable
int sens_pin = 4; //makes pin 4 a variable
int short_blink = 500;
int long_blink = 1000;


void setup() {
  // put your setup code here, to run once:
  pinMode(led_pin,OUTPUT); //pin 13 in an output
  pinMode(sens_pin,INPUT); //pin 4 is an input
}

void loop() {
  // put your main code here, to run repeatedly:

for(int i = 0; i < 3; i++){
   digitalWrite(led_pin, HIGH);
   delay(short_blink);
   digitalWrite(led_pin, LOW);
   delay(short_blink);}
for(int i = 0; i < 3; i++){
   digitalWrite(led_pin, HIGH);
   delay(long_blink);
   digitalWrite(led_pin, LOW);
   delay(long_blink);}
for(int i = 0; i < 3; i++){
   digitalWrite(led_pin, HIGH);
   delay(short_blink);
   digitalWrite(led_pin, LOW);
   delay(short_blink);}
delay(1000);
}
