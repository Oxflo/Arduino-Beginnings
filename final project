This program takes a bunch of inputs and maps them as a game controller in windows 11. It will contain 32 digital buttons, at least 1 8-way hat switch, and 5 analog levers. */
#include <Joystick.h>
Joystick_ Joystick;

//varaiable for motors
const int num_motors = 5;
int motor_phaseA_pins[num_motors] = {14, 16, 18, 20, 22};
int motor_phaseB_pins[num_motors] = {15, 17, 19, 21, 23};
volatile int motor_pos[num_motors];}

//variables for rotary encoders
const int num_enc = 6;
int enc_phaseA_pins[num_enc] = {24, 26, 28, 30, 32, 34};
int enc_phaseB_pins[num_enc] = {25, 27, 29, 31, 33, 35};
unsigned long encoder_L_time[num_enc];
unsigned long encoder_R_time[num_enc];

//variables for motor PWM outputs
int motor_PWM_pins[num_motors] = {9, 10, 11, 12, 13};
int motor_direction_pins[num_motors] = {36, 37, 38, 39, 40}


void setup() {
noInterrupts();

Joystick.begin();

for(int i = 14; i < 36; i++) {pinMode(i, INPUT_PULLUP);}
for(int i = 9; i < 14; i++) {pinMode(i, OIUTPUT);}
for(int i = 36; i < 41; i++) {pinMode(i, OUTPUT);}


attachInterrupt(digitalPinToInterrupt(motor_phaseA_pins[0]), read_motor0, CHANGE);
attachInterrupt(digitalPinToInterrupt(motor_phaseA_pins[1]), read_motor1, CHANGE);
attachInterrupt(digitalPinToInterrupt(motor_phaseA_pins[2]), read_motor2, CHANGE);
attachInterrupt(digitalPinToInterrupt(motor_phaseA_pins[3]), read_motor3, CHANGE);
attachInterrupt(digitalPinToInterrupt(motor_phaseA_pins[4]), read_motor4, CHANGE);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[0]), read_rot_enc0, RISING);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[1]), read_rot_enc1, RISING);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[2]), read_rot_enc2, RISING);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[3]), read_rot_enc3, RISING);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[4]), read_rot_enc4, RISING);
attachInterrupt(digitalPinToInterrupt(enc_phaseA_pins[5]), read_rot_enc5, RISING);

interrupts();}



void loop() {
  map_encoders();
  read_rotary_encoder();
  button_thing();}

  
///////supporting functions///////

 //These functions simply allow the interupts to interact with the read_encoder() functions as the read_encoder() functions rely on a list and the variarable "i" and interupts can't do that to my knowledge.
void read_motor0() {read_encoder(0);} 
void read_motor1() {read_encoder(1);}
void read_motor2() {read_encoder(2);}
void read_motor3() {read_encoder(3);}
void read_motor4() {read_encoder(4);}
void read_rot_enc0() {read_rot_enc(0);}
void read_rot_enc0() {read_rot_enc(2);}
void read_rot_enc0() {read_rot_enc(4);}
void read_rot_enc0() {read_rot_enc(6);}
void read_rot_enc0() {read_rot_enc(8);}
void read_rot_enc0() {read_rot_enc(10);}

 //This function does the comparison between phase A and phase B (pA and pB respectively) to determine which direction the motor is moving and then also tracks the amount the motor has rotated.
void read_encoder(int i) {
  int pA = !digitalRead(motor_phaseA_pins[i]);
  int pB = !digitalRead(motor_phaseA_pins[i]);
  if(pA == HIGH) {
    if(pB == HIGH) {motor_pos[i] ++;}
    else {motor_pos[i] --;}}
  else {
    if(pB == LOW) {motor_pos[i] ++;}
    else {motor_pos[i] --;}}}

/*This function takes the motor position and securely stores it in a non_volatile variable to prevent corruption. The map() function does all the math to take the upper and lower limits of the motor (-50 and 50 in this case) and translate them into a full range portentiometer (0 and 1023 in this case).
The Joystick.setAxis functions takes the mapped output from the map() function and tells windows what axis the input belongs to.*/
void map_encoders() {
    for(int i = 0; i < num_motors; i++) {
    noInterrupts();
    int pos = motor_pos[i];
    interrupts();

    int mapped = map(pos, -10, 10, 0, 1023);
    if(i == 0) Joystick.setZAxis(mapped);
    if(i == 1) Joystick.setRxAxis(mapped);
    if(i == 2) Joystick.setRyAxis(mapped);
    if(i == 3) Joystick.setRzAxis(mapped);
    if(i == 4) Joystick.setThrottle(mapped);}}

//This function read the left and right rotation features of the rotary encoders and give a pulse for either direction. The "position" of the dial is not tracked and simply gives a pulse when the knob is turned.
void read_rot_enc(int i) {
  int epA = !digitalRead(enc_phaseA_pins[i]);
  int epB = !digitalRead(enc_phaseB_pins[i]);

  if(epB == epA){
    Joystick.pressButton(i);
    encoder_L_time[i] = millis();}
  else{
    Joystick.pressButton(i + 1);
    encoder_R_time[i] = millis();}

  if(millis() - encoder_L_time[i] > 25) {Joystick.releaseButton(1);}
  if(millis() - encoder_R_time[i] > 25) {Joystick.releaseButton(2);}}

