#include <LiquidCrystal.h>
LiquidCrystal lcd(13, 12, 11, 10, 9, 8);

const int switch_pin = 2;
int switch_state = 0;
int prev_switch_state = 0;
int reply;

void read_switch_and_reply() {
  switch_state = digitalRead(switch_pin);
  if(switch_state != prev_switch_state){
    if(switch_state == LOW) {
      reply = random(8);
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("The ball says:");
      lcd.setCursor(0, 1);
      switch(reply) {
        case 0:
        lcd.print("Yes");
        break;
        case 1:
        lcd.print("Most likely");
        break;
        case 2:
        lcd.print("Certainly");
        break;
        case 3:
        lcd.print("Outlook Good");
        break;
        case 4:
        lcd.print("Unsure");
        break;
        case 5:
        lcd.print("Ask Again");
        break;
        case 6:
        lcd.print("Doubtful");
        break;
        case 7:
        lcd.print("No");
        break;}}
    prev_switch_state = switch_state;}}

void setup_lcd() {
  lcd.begin(16, 2);
  lcd.print("Ask the");
  lcd.setCursor(0, 1);
  lcd.print("Crystal Ball!");
  Serial.begin(9600);}

void setup() {
  setup_lcd();
  pinMode(switch_pin, INPUT);}

void loop() {
  Serial.println(switch_state);
  read_switch_and_reply();}
