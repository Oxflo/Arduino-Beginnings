int green_led = 10; //green light pin
int red_led = 9; //red light pin
int blue_led = 8; //yellow light pin
int sens_pin = A0; //pin for switch input
float sensor_volt = (analogRead(sens_pin) / 1024) *5;
float temp = (sensor_volt - 0.5) * 100;
int base_temp = 20;

void light_control() {
  if(temp < base_temp){
    digitalWrite(green_led, LOW);
    digitalWrite(red_led, LOW);
    digitalWrite(blue_led, LOW);}
  if(temp > (base_temp + 2)){
    digitalWrite(green_led, HIGH);
    digitalWrite(red_led, LOW);
    digitalWrite(blue_led, LOW);}
  if(temp > (base_temp + 4)){
    digitalWrite(green_led, HIGH);
    digitalWrite(red_led, HIGH);
    digitalWrite(blue_led, LOW);}
  if(temp > (base_temp + 6)){
    digitalWrite(green_led, HIGH);
    digitalWrite(red_led, HIGH);
    digitalWrite(blue_led, HIGH);}
    delay(1);}

void setup() {
  // put your setup code here, to run once:
for(int pin_number = 8; pin_number < 11; pin_number++){
  pinMode(pin_number, OUTPUT);
  digitalWrite(pin_number, LOW);}}

void loop() {
  // put your main code here, to run repeatedly:
light_control();}
