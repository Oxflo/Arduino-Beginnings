int yellow_led = 2; //green light pin
int orange_led = 3; //red light pin
int red_led = 4; //yellow light pin
int sens_pin = A0; //pin for temp probe input

int base_temp = 28;
float temp;
float sensor_volt;
unsigned long last_check_time = 0;
int check_int = 250;
unsigned long last_print_time = 0;
int print_int = 500;

//reads sensor input and stores the input as a voltage and tmep
void read_sensor() {
  sensor_volt = (analogRead(sens_pin) / 1024.0) * 5.0;
  temp = (sensor_volt - 0.5) * 100;}

//prints all relevant data form the sensor
void print_sensor() {
  if(millis() - last_print_time > print_int) {
    last_print_time = millis();
    Serial.print("Sensor Voltage: ");
    Serial.print(sensor_volt);
    Serial.print(" Sensor Temp: ");
    Serial.print(temp);
    Serial.println("°C");}}

//controls lights based on the data collected
void light_control() {
  if(millis() - last_check_time > check_int) {
    last_check_time = millis();
    if(temp < base_temp){
      for(int i = 2; i < 5; i++)
        digitalWrite(i, LOW);}
    else if(temp > (base_temp) && temp < (base_temp + 2)) {
      digitalWrite(yellow_led, HIGH);
      digitalWrite(orange_led, LOW);
      digitalWrite(red_led, LOW);}
    else if(temp > (base_temp + 2) && temp < (base_temp + 4)) {
      digitalWrite(yellow_led, HIGH);
      digitalWrite(orange_led, HIGH);
      digitalWrite(red_led, LOW);}
    else if(temp > (base_temp + 4)){
      for(int i = 2; i < 5; i++)
        digitalWrite(i, HIGH);}}}

//runs once
void setup() {
  for(int i = 2; i < 5; i++) {
    pinMode(i, OUTPUT);
    digitalWrite(i, LOW);}
  pinMode(sens_pin, INPUT);
  Serial.begin(9600);}

//runs until the heat death of the unvierse. Or it gets unplugged
void loop() {
  read_sensor();
  print_sensor();
  light_control();}
